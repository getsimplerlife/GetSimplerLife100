{
  "name": "team-site-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun run serve.ts",
    "publish": "bun run publish.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tanstack .run .vercel/output node_modules/.cache",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.3",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.9"
  }
}
